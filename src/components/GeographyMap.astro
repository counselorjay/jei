---
import widgetData from '../data/jei_widget_data.json';

const geo = widgetData.geography;
const topStates = geo.top_us_states; // [["CA",25.6], ...]
const topCountries = geo.top_non_us_countries; // [["IN",25],...]

// We render a stylized "tile-grid" of the US (no SVG map dependency).
// The grid below approximates state positions and lets us color-code
// the top tier without shipping a 100KB topojson.
//
// Layout: rows = roughly north-to-south, columns = roughly west-to-east.
// Cells are 2-letter postal codes. null = blank.
const TILE_GRID = [
  [null, null, null, null, null, null, null, null, null, null, 'ME'],
  [null, 'WA', null, null, 'MT', 'ND', 'MN', null, null, 'WI', 'VT', 'NH'],
  [null, 'OR', 'ID', null, 'WY', 'SD', 'IA', 'IL', 'IN', 'MI', 'NY', 'MA'],
  [null, 'CA', 'NV', 'UT', 'CO', 'NE', 'MO', 'KY', 'OH', 'PA', 'NJ', 'CT', 'RI'],
  [null, null, 'AZ', 'NM', null, 'KS', 'AR', 'TN', 'WV', 'VA', 'MD', 'DE'],
  [null, null, null, null, 'OK', 'LA', 'MS', 'AL', 'GA', 'NC', 'SC'],
  ['HI', 'AK', null, null, 'TX', null, null, null, 'FL', null],
];

const stateMap = Object.fromEntries(topStates);
function intensity(code) {
  const v = stateMap[code];
  if (v == null) return 0;
  if (v >= 20) return 5;
  if (v >= 7) return 4;
  if (v >= 5) return 3;
  if (v >= 3) return 2;
  return 1;
}

// approximate-concentration caveat copy lives in the tooltip.
---
<section
  aria-labelledby="geo-heading"
  class="rounded-xl border border-ink-300 bg-white p-6 md:p-8 my-6"
>
  <div class="flex items-start justify-between gap-4 flex-wrap">
    <div>
      <h3 id="geo-heading" class="text-xl font-semibold tracking-tight text-ink-900">
        Where published authors are based
      </h3>
      <p class="mt-1 text-sm text-ink-500 max-w-xl">
        Approximate concentration of published authors by US state and by non-US country, from the 592-paper corpus.
      </p>
    </div>
    <div class="text-xs text-ink-500 text-right">
      <p><span class="font-medium text-ink-700">{geo.us_pct}%</span> US <span class="mx-1">·</span> <span class="font-medium text-ink-700">{geo.non_us_pct}%</span> non-US</p>
      <p class="mt-1">{geo.us_papers_count} of {widgetData.corpus_total} US papers</p>
    </div>
  </div>

  <div class="mt-5 rounded-md border border-warn/40 bg-warn-soft px-4 py-3 text-xs text-ink-700">
    <span class="font-semibold text-warn">A note on precision:</span>
    State and country are inferred from the published affiliation block. Per the corpus QA, about 55.6 percent of these inferences are name-only. Treat single-state percentages as approximate, plus or minus 5 to 10 points. Of {geo.us_papers_count} US papers, {geo.us_papers_state_unknown_count} had no inferable state, so the per-state denominator is {geo.us_papers_with_state_inferred_count}, not {geo.us_papers_count}.
  </div>

  <div class="mt-6 grid md:grid-cols-3 gap-6">
    <div class="md:col-span-2 overflow-x-auto">
      <div class="inline-block">
        {TILE_GRID.map((row) => (
          <div class="flex">
            {row.map((code) => {
              if (!code) return <div class="w-10 h-10 m-0.5"></div>;
              const lvl = intensity(code);
              const pct = stateMap[code];
              const cls = [
                'w-10 h-10 m-0.5 rounded-sm flex items-center justify-center text-[10px] font-semibold border',
                lvl === 5 ? 'bg-accent-dark text-white border-accent-dark' :
                lvl === 4 ? 'bg-accent text-white border-accent' :
                lvl === 3 ? 'bg-emerald-300 text-emerald-950 border-emerald-300' :
                lvl === 2 ? 'bg-emerald-100 text-emerald-900 border-emerald-200' :
                lvl === 1 ? 'bg-emerald-50 text-emerald-900 border-emerald-100' :
                'bg-slate-50 text-ink-500 border-slate-200',
              ].join(' ');
              const tip = pct != null
                ? `${code}: about ${pct}% of US-with-state-inferred (n=${geo.us_papers_with_state_inferred_count}). Single-state numbers are approximate, plus or minus 5 to 10 points.`
                : `${code}: not in the top tier of US states. Single-state numbers are approximate, plus or minus 5 to 10 points.`;
              return (
                <div class={cls} title={tip} aria-label={tip}>
                  {code}
                </div>
              );
            })}
          </div>
        ))}
      </div>
      <div class="mt-3 flex items-center gap-2 text-[11px] text-ink-500">
        <span>less</span>
        <span class="inline-block w-4 h-4 rounded-sm bg-emerald-50 border border-emerald-100"></span>
        <span class="inline-block w-4 h-4 rounded-sm bg-emerald-100 border border-emerald-200"></span>
        <span class="inline-block w-4 h-4 rounded-sm bg-emerald-300 border border-emerald-300"></span>
        <span class="inline-block w-4 h-4 rounded-sm bg-accent border border-accent"></span>
        <span class="inline-block w-4 h-4 rounded-sm bg-accent-dark border border-accent-dark"></span>
        <span>more</span>
      </div>
    </div>

    <div>
      <h4 class="font-semibold text-ink-700 text-sm">Top non-US countries</h4>
      <p class="text-xs text-ink-500 mt-0.5">Counts of papers, not percentages.</p>
      <ul class="mt-3 space-y-1.5 text-sm">
        {topCountries.map((row) => (
          <li class="flex items-center justify-between border-b border-ink-300/50 pb-1">
            <span class="font-medium text-ink-900">{row[0]}</span>
            <span class="text-ink-500">{row[1]} papers</span>
          </li>
        ))}
      </ul>
    </div>
  </div>
</section>
